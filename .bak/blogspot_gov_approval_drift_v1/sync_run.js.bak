import { json, nowSec } from "../../../_lib.js";
import {
  requireBlogspotAccess,
  getBlogspotConfig,
  getBlogspotOAuthConfig,
  refreshBlogspotAccessToken,
  bloggerFetch,
  bloggerUrl,
  getSyncConfigValue,
  setSyncState,
  addSyncLog,
  getDirtyLocalItems,
  getLinkedLocalItems,
  markMapDirty
} from "./_service.js";

function s(v){ return String(v || "").trim(); }

async function pushPost(env, cfg, accessToken, row, actor_user_id){
  const labels = (() => {
    try{ return JSON.parse(String(row.labels_json || "[]")); }
    catch{ return []; }
  })();

  const isDraft = String(row.status || "draft") !== "published" ? "true" : "false";
  const remoteId = s(row.external_id || row.remote_id);
  const hasRemote = !!remoteId;

  const endpoint = hasRemote
    ? `https://www.googleapis.com/blogger/v3/blogs/${encodeURIComponent(cfg.blog_id)}/posts/${encodeURIComponent(remoteId)}?isDraft=${isDraft}`
    : `https://www.googleapis.com/blogger/v3/blogs/${encodeURIComponent(cfg.blog_id)}/posts?isDraft=${isDraft}`;

  const payload = {
    kind: "blogger#post",
    title: row.title || "",
    content: row.content_html || "",
    labels: Array.isArray(labels) ? labels : []
  };

  const res = await bloggerFetch(endpoint, {
    method: hasRemote ? "PUT" : "POST",
    headers: {
      "authorization": "Bearer " + accessToken,
      "content-type": "application/json"
    },
    body: JSON.stringify(payload)
  });

  const now = nowSec();

  if(!res.ok){
    await markMapDirty(env, "post", row.id, {
      remote_id: remoteId || null,
      title: row.title || "",
      slug: row.slug || "",
      dirty: 1,
      deleted_local: 0,
      deleted_remote: 0,
      sync_state: "error",
      sync_error: "push_failed",
      last_synced_at: now,
      last_actor_user_id: actor_user_id,
      action: hasRemote ? "remote_update" : "remote_create",
      direction: "push",
      status: "error",
      message: "post push failed",
      payload_json: { http: res.status, body: res.data || res.text || "" },
      response_excerpt: res.text || null
    });
    return { ok:false, kind:"post", id: row.id, status: res.status };
  }

  const remote = res.data || {};
  const finalRemoteId = s(remote.id || remoteId);

  await env.DB.prepare(`
    UPDATE cms_posts
    SET external_id=?,
        blog_id=?,
        url=?,
        remote_url=?,
        remote_status='linked',
        published_at=?,
        last_remote_sync_at=?,
        updated_at=?
    WHERE id=?
  `).bind(
    finalRemoteId || null,
    cfg.blog_id,
    remote.url || row.url || null,
    remote.url || row.url || null,
    remote.published ? Math.floor(new Date(remote.published).getTime() / 1000) : null,
    now,
    now,
    row.id
  ).run();

  await markMapDirty(env, "post", row.id, {
    remote_id: finalRemoteId,
    title: row.title || "",
    slug: row.slug || "",
    remote_url: remote.url || null,
    remote_status: "linked",
    remote_updated: s(remote.updated || ""),
    last_synced_at: now,
    last_pushed_at: now,
    dirty: 0,
    deleted_local: 0,
    deleted_remote: 0,
    sync_state: "synced",
    sync_error: null,
    last_actor_user_id: actor_user_id,
    action: hasRemote ? "remote_update" : "remote_create",
    direction: "push",
    status: "ok",
    message: "post pushed to blogger",
    payload_json: {
      remote_id: finalRemoteId,
      remote_url: remote.url || "",
      local_id: row.id
    }
  });

  return { ok:true, kind:"post", id: row.id, remote_id: finalRemoteId };
}

