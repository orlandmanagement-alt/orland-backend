  return { ok:true, kind:"page", id: row.id, remote_id: finalRemoteId };
}

async function pullPost(env, cfg, row, actor_user_id){
  const remoteId = s(row.external_id || row.remote_id);
  if(!remoteId) return { ok:false, skipped:true };

  const now = nowSec();
  const url = bloggerUrl(cfg.blog_id, "/posts/" + encodeURIComponent(remoteId), {}, cfg.api_key);
  const res = await bloggerFetch(url, { method:"GET" });

  if(!res.ok){
    if(Number(res.status) === 404){
      await markMapDirty(env, "post", row.id, {
        remote_id: remoteId,
        title: row.title || "",
        slug: row.slug || "",
        last_synced_at: now,
        dirty: 1,
        deleted_local: 0,
        deleted_remote: 1,
        sync_state: "remote_deleted",
        sync_error: null,
        last_actor_user_id: actor_user_id,
        action: "remote_refresh_missing",
        direction: "pull",
        status: "ok",
        message: "remote post missing",
        payload_json: { remote_id: remoteId }
      });
      await env.DB.prepare(`
        UPDATE cms_posts
        SET remote_status='deleted_remote',
            last_remote_sync_at=?,
            updated_at=?
        WHERE id=?
      `).bind(now, now, row.id).run();
      return { ok:true, missing:true, kind:"post", id: row.id };
    }

    await markMapDirty(env, "post", row.id, {
      remote_id: remoteId,
      title: row.title || "",
      slug: row.slug || "",
      last_synced_at: now,
      dirty: Number(row.dirty || 0) ? 1 : 0,
      deleted_local: 0,
      deleted_remote: 0,
      sync_state: "error",
      sync_error: "pull_failed",
      last_actor_user_id: actor_user_id,
      action: "remote_refresh",
      direction: "pull",
      status: "error",
      message: "remote post refresh failed",
      payload_json: { http: res.status, body: res.data || res.text || "" },
      response_excerpt: res.text || null
    });
    return { ok:false, kind:"post", id: row.id };
  }

  const remote = res.data || {};
  await env.DB.prepare(`
    UPDATE cms_posts
    SET external_id=?,
        blog_id=?,
        url=?,
        remote_url=?,
        remote_status='linked',
        published_at=?,
        last_remote_sync_at=?,
        updated_at=?
    WHERE id=?
  `).bind(
    s(remote.id || remoteId),
    cfg.blog_id,
    remote.url || row.url || null,
    remote.url || row.url || null,
    remote.published ? Math.floor(new Date(remote.published).getTime() / 1000) : null,
    now,
    now,
    row.id
  ).run();

  await markMapDirty(env, "post", row.id, {
    remote_id: s(remote.id || remoteId),
    title: row.title || "",
    slug: row.slug || "",
    remote_url: remote.url || null,
    remote_status: "linked",
    remote_updated: s(remote.updated || ""),
    last_synced_at: now,
    dirty: Number(row.dirty || 0) ? 1 : 0,
    deleted_local: 0,
    deleted_remote: 0,
    sync_state: Number(row.dirty || 0) ? "conflict_possible" : "synced",
    sync_error: null,
    last_actor_user_id: actor_user_id,
    action: "remote_refresh",
    direction: "pull",
    status: "ok",
    message: Number(row.dirty || 0) ? "remote post refreshed while local dirty" : "remote post refreshed",
    payload_json: {
      remote_id: remote.id || remoteId,
      remote_url: remote.url || ""
    }
  });

  return { ok:true, kind:"post", id: row.id };
}

