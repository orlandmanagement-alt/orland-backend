export default function(Orland){
  const cards = [
    {
      title: "Global Settings",
      desc: "Atur policy global verification untuk client dan talent.",
      path: "/config/global",
      icon: "fa-solid fa-sliders"
    },
    {
      title: "Cron Global",
      desc: "Atur automation cleanup verification dan run status.",
      path: "/config/cron-global",
      icon: "fa-solid fa-clock-rotate-left"
    },
    {
      title: "Security Policy",
      desc: "Kelola security policy, rate limit, account lock, dan header.",
      path: "/security/policy",
      icon: "fa-solid fa-shield-halved"
    },
    {
      title: "Analytics Config",
      desc: "Konfigurasi analytics dan pengaturan integrasi terkait.",
      path: "/config/analytics",
      icon: "fa-solid fa-chart-line"
    },
    {
      title: "Blogspot Settings",
      desc: "Kelola integrasi Blogger, API config, dan sync behavior.",
      path: "/integrations/blogspot/settings",
      icon: "fa-brands fa-blogger-b"
    }
  ];

  function cardHtml(x){
    return `
      <button
        type="button"
        class="settingsCard w-full text-left rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5 hover:bg-slate-50 dark:hover:bg-white/5 transition"
        data-path="${x.path}"
      >
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
            <i class="${x.icon} text-lg"></i>
          </div>
          <div class="min-w-0">
            <div class="text-lg font-extrabold text-slate-900 dark:text-white">${x.title}</div>
            <div class="text-sm text-slate-500 mt-1">${x.desc}</div>
            <div class="text-xs text-primary font-black mt-4">${x.path}</div>
          </div>
        </div>
      </button>
    `;
  }

  return {
    title:"Settings Center",
    async mount(host){
      host.innerHTML = `
        <div class="space-y-5 max-w-7xl">
          <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div>
                <div class="text-2xl font-extrabold">Settings Center</div>
                <div class="text-slate-500 mt-1">Pusat pengaturan enterprise untuk konfigurasi utama sistem.</div>
              </div>
              <div class="flex gap-2 flex-wrap">
                <button id="goSecurityModule" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder font-black text-sm">
                  Security Module
                </button>
                <button id="goVerificationDashboard" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder font-black text-sm">
                  Verification Dashboard
                </button>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            ${cards.map(cardHtml).join("")}
          </div>

          <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
            <div class="text-xl font-extrabold">Notes</div>
            <div class="mt-3 grid grid-cols-1 lg:grid-cols-3 gap-3 text-sm text-slate-500">
              <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
                Module lama tetap aktif, Settings Center hanya sebagai hub.
              </div>
              <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
                Struktur ini cocok untuk enterprise app agar config tidak tersebar.
              </div>
              <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
                Tahap berikutnya bisa dibuat kategori tab dan search settings global.
              </div>
            </div>
          </div>
        </div>
      `;

      host.querySelectorAll(".settingsCard").forEach(btn=>{
        btn.addEventListener("click", ()=>{
          const path = btn.getAttribute("data-path");
          if(path) Orland.navigate(path);
        });
      });

      host.querySelector("#goSecurityModule")?.addEventListener("click", ()=>{
        Orland.navigate("/security");
      });

      host.querySelector("#goVerificationDashboard")?.addEventListener("click", ()=>{
        Orland.navigate("/security/verification-dashboard");
      });
    }
  };
}
