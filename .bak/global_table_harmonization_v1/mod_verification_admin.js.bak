export default function(Orland){
  const esc = (s)=>String(s ?? "").replace(/[&<>"']/g, m => ({
    "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"
  }[m]));

  async function apiLoad(status="", q=""){
    const qs = new URLSearchParams();
    if(status) qs.set("status", status);
    if(q) qs.set("q", q);
    return await Orland.api("/api/verification/admin_reviews" + (qs.toString() ? ("?" + qs.toString()) : ""));
  }

  async function apiReview(payload){
    return await Orland.api("/api/verification/review_kyc", {
      method: "POST",
      body: JSON.stringify(payload)
    });
  }

  function badge(status){
    const s = String(status || "").toLowerCase();
    if(s === "approved" || s === "verified"){
      return `<span class="px-2 py-1 rounded-full bg-emerald-100 text-emerald-700 text-[11px] font-black">${esc(s)}</span>`;
    }
    if(s === "rejected"){
      return `<span class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-[11px] font-black">${esc(s)}</span>`;
    }
    return `<span class="px-2 py-1 rounded-full bg-amber-100 text-amber-700 text-[11px] font-black">${esc(s || "pending")}</span>`;
  }

  function prettyJson(v){
    try{ return JSON.stringify(v || {}, null, 2); }
    catch{ return "{}"; }
  }

  return {
    title:"Verification Admin Review",
    async mount(host){
      host.innerHTML = `
        <div class="space-y-5 max-w-7xl">
          <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div>
                <div class="text-2xl font-extrabold">Verification Admin Review</div>
                <div class="text-slate-500 mt-1">Review request KYC untuk client dan talent.</div>
              </div>
              <button id="btnReload" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder font-black text-sm">
                <i class="fa-solid fa-rotate mr-2"></i>Reload
              </button>
            </div>

            <div class="mt-4 grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-3">
              <select id="qStatus" class="w-full px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold">
                <option value="">All status</option>
                <option value="pending">pending</option>
                <option value="approved">approved</option>
                <option value="rejected">rejected</option>
                <option value="verified">verified</option>
              </select>
              <input id="qSearch" class="w-full px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold" placeholder="Cari email / display_name / user_id / verification_id">
            </div>

            <div id="msg" class="mt-4 text-sm text-slate-500"></div>
          </div>

          <div id="listBox" class="space-y-4"></div>
        </div>
      `;

      const q = (id)=>host.querySelector("#" + id);
      let ITEMS = [];

      function renderList(){
        if(!ITEMS.length){
          q("listBox").innerHTML = `
            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-6 text-sm text-slate-500">
              No verification data.
            </div>
          `;
          return;
        }

        q("listBox").innerHTML = ITEMS.map(row => `
          <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter overflow-hidden">
            <div class="p-5">
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div class="min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <div class="text-lg font-extrabold">${esc(row.display_name || row.email_norm || row.user_id)}</div>
                    ${badge(row.status)}
                  </div>
                  <div class="mt-2 text-xs text-slate-500 space-y-1">
                    <div>user_id: ${esc(row.user_id || "-")}</div>
                    <div>verification_id: ${esc(row.id || "-")}</div>
                    <div>email: ${esc(row.email_norm || "-")}</div>
                  </div>
                </div>

                <div class="flex gap-2 flex-wrap">
                  <button class="btnApprove px-4 py-2.5 rounded-2xl bg-emerald-600 text-white font-black text-sm" data-id="${esc(row.id)}">Approve</button>
                  <button class="btnReject px-4 py-2.5 rounded-2xl bg-red-600 text-white font-black text-sm" data-id="${esc(row.id)}">Reject</button>
                </div>
              </div>

              <div class="mt-4 grid grid-cols-1 xl:grid-cols-2 gap-4">
                <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
                  <div class="text-xs font-black text-slate-500">Evidence JSON</div>
                  <pre class="mt-3 text-[11px] whitespace-pre-wrap break-words bg-slate-50 dark:bg-black/20 border border-slate-200 dark:border-darkBorder rounded-2xl p-3">${esc(prettyJson(row.evidence || {}))}</pre>
                </div>

                <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
                  <div class="text-xs font-black text-slate-500">Review Note</div>
                  <textarea class="reviewNote w-full min-h-[160px] mt-3 px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold" data-id="${esc(row.id)}" placeholder="Opsional note review"></textarea>
                  <div class="mt-3 text-xs text-slate-500">
                    created_at: ${esc(row.created_at || "-")} • updated_at: ${esc(row.updated_at || "-")} • reviewed_at: ${esc(row.reviewed_at || "-")}
                  </div>
                </div>
              </div>
            </div>
          </div>
        `).join("");

        q("listBox").querySelectorAll(".btnApprove").forEach(btn => {
          btn.onclick = async ()=>{
            const id = btn.getAttribute("data-id");
            const note = q("listBox").querySelector(`.reviewNote[data-id="${CSS.escape(id)}"]`)?.value || "";
            await submitReview(id, "approve", note);
          };
        });

        q("listBox").querySelectorAll(".btnReject").forEach(btn => {
          btn.onclick = async ()=>{
            const id = btn.getAttribute("data-id");
            const note = q("listBox").querySelector(`.reviewNote[data-id="${CSS.escape(id)}"]`)?.value || "";
            await submitReview(id, "reject", note);
          };
        });
      }

      async function submitReview(id, action, note){
        q("msg").className = "mt-4 text-sm text-slate-500";
        q("msg").textContent = "Saving review...";
        const r = await apiReview({ id, action, note });

        if(r.status !== "ok"){
          q("msg").className = "mt-4 text-sm text-red-500";
          q("msg").textContent = "Review failed: " + (r.data?.message || r.status);
          return;
        }

        q("msg").className = "mt-4 text-sm text-emerald-600";
        q("msg").textContent = "Review saved.";
        await load();
      }

      async function load(){
        q("msg").className = "mt-4 text-sm text-slate-500";
        q("msg").textContent = "Loading...";

        const r = await apiLoad(
          q("qStatus").value,
          q("qSearch").value.trim()
        );

        if(r.status !== "ok"){
          q("msg").className = "mt-4 text-sm text-red-500";
          q("msg").textContent = "Load failed: " + r.status;
          return;
        }

        ITEMS = Array.isArray(r.data?.items) ? r.data.items : [];
        renderList();

        q("msg").className = "mt-4 text-sm text-emerald-600";
        q("msg").textContent = "Loaded.";
      }

      q("btnReload").onclick = load;
      q("qStatus").onchange = load;
      q("qSearch").oninput = ()=>{
        clearTimeout(window.__verifyAdminSearchTimer);
        window.__verifyAdminSearchTimer = setTimeout(load, 250);
      };

      await load();
    }
  };
}
