import { json, requireAuth, hasRole } from "../_lib.js";

function normPath(p){
  p = String(p || "").trim();
  if(!p) return "/";
  if(!p.startsWith("/")) p = "/" + p;
  p = p.replace(/\/+/g, "/").replace(/\/+$/, "");
  return p || "/";
}

function shouldSkipRoute(row){
  const code = String(row?.code || "").trim().toLowerCase();
  const path = normPath(row?.path || "/");

  const skipCodes = new Set([
    "access_control",
    "config"
  ]);

  const skipPaths = new Set([
    "/access-control",
    "/config"
  ]);

  if(skipCodes.has(code)) return true;
  if(skipPaths.has(path)) return true;

  return false;
}

