export async function onRequestPost({ request, env }){
  const a = await requireBlogspotAccess(env, request, false);
  if(!a.ok) return a.res;

  const cfg = await getBlogspotConfig(env);
  const enabled = await getSyncConfigValue(env, "enabled", "0");
  const sync_direction = await getSyncConfigValue(env, "sync_direction", "bidirectional");
  const sync_posts_enabled = await getSyncConfigValue(env, "sync_posts_enabled", "1");
  const sync_pages_enabled = await getSyncConfigValue(env, "sync_pages_enabled", "1");
  const sync_widgets_enabled = await getSyncConfigValue(env, "sync_widgets_enabled", "1");
  const write_enabled = await getSyncConfigValue(env, "write_enabled", "0");
  const cron_driver = await getSyncConfigValue(env, "cron_driver", "cron_trigger");

  const now = nowSec();
  await setSyncState(env, "last_run_at", now);
  await setSyncState(env, "last_status", "running");
  await setSyncState(env, "last_message", "sync executor started");

  if(enabled !== "1"){
    await setSyncState(env, "last_status", "skipped");
    await setSyncState(env, "last_message", "sync disabled");
    await addSyncLog(env, {
      direction: "system",
      kind: "system",
      action: "run",
      status: "skipped",
      message: "sync disabled"
    });
    return json(200, "ok", { ran:false, status:"skipped", message:"sync disabled" });
  }

  if(!cfg.enabled || !cfg.blog_id || !cfg.api_key){
    await setSyncState(env, "last_status", "error");
    await setSyncState(env, "last_message", "missing blogspot config");
    await addSyncLog(env, {
      direction: "system",
      kind: "system",
      action: "run",
      status: "error",
      message: "missing blogspot config"
    });
    return json(200, "ok", { ran:false, status:"error", message:"missing blogspot config" });
  }

  let accessToken = null;
  if((sync_direction === "push" || sync_direction === "bidirectional") && write_enabled === "1"){
    const oauth = await getBlogspotOAuthConfig(env);
    if(!oauth.enabled){
      await setSyncState(env, "last_status", "error");
      await setSyncState(env, "last_message", "oauth disabled for push");
      return json(200, "ok", { ran:false, status:"error", message:"oauth disabled for push" });
    }

    const tk = await refreshBlogspotAccessToken(env);
    if(!tk.ok){
      await setSyncState(env, "last_status", "error");
      await setSyncState(env, "last_message", "oauth refresh failed");
      return json(200, "ok", { ran:false, status:"error", message:"oauth refresh failed", detail: tk.data || null });
    }
    accessToken = tk.access_token;
  }

  const summary = {
    direction: sync_direction || "bidirectional",
    sync_posts_enabled: sync_posts_enabled !== "0",
    sync_pages_enabled: sync_pages_enabled !== "0",
    sync_widgets_enabled: sync_widgets_enabled !== "0",
    cron_driver: cron_driver || "cron_trigger",
    push: { posts:0, pages:0, failed:0 },
    pull: { posts:0, pages:0, missing:0, failed:0 },
    widgets: {
      enabled: sync_widgets_enabled !== "0",
      note: "widget remote sync not implemented yet"
    }
  };

  if((sync_direction === "push" || sync_direction === "bidirectional") && write_enabled === "1"){
    if(sync_posts_enabled !== "0"){
      const dirtyPosts = await getDirtyLocalItems(env, "post", 50);
      for(const row of dirtyPosts){
        const r = await pushPost(env, cfg, accessToken, row, a.uid || null);
        if(r.ok) summary.push.posts++;
        else summary.push.failed++;
      }
    }

    if(sync_pages_enabled !== "0"){
      const dirtyPages = await getDirtyLocalItems(env, "page", 50);
      for(const row of dirtyPages){
        const r = await pushPage(env, cfg, accessToken, row, a.uid || null);
        if(r.ok) summary.push.pages++;
        else summary.push.failed++;
      }
    }
  }

  if(sync_direction === "pull" || sync_direction === "bidirectional"){
    if(sync_posts_enabled !== "0"){
      const linkedPosts = await getLinkedLocalItems(env, "post", 50);
      for(const row of linkedPosts){
        const r = await pullPost(env, cfg, row, a.uid || null);
        if(r.ok && r.missing) summary.pull.missing++;
        else if(r.ok) summary.pull.posts++;
        else if(!r.skipped) summary.pull.failed++;
      }
    }

    if(sync_pages_enabled !== "0"){
      const linkedPages = await getLinkedLocalItems(env, "page", 50);
      for(const row of linkedPages){
        const r = await pullPage(env, cfg, row, a.uid || null);
        if(r.ok && r.missing) summary.pull.missing++;
        else if(r.ok) summary.pull.pages++;
        else if(!r.skipped) summary.pull.failed++;
      }
    }
  }

  await setSyncState(env, "last_status", "ok");
  await setSyncState(env, "last_success_at", nowSec());
  await setSyncState(env, "last_message", "sync executor finished");

  await addSyncLog(env, {
    direction: summary.direction,
    kind: "system",
    actor_user_id: a.uid || null,
    action: "run",
    status: "ok",
    message: "sync executor finished",
    payload_json: summary
  });

  return json(200, "ok", {
    ran: true,
    status: "ok",
    summary
  });
}
