export default function(Orland){
  const esc = (s)=>String(s ?? "").replace(/[&<>"']/g, m => ({
    "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"
  }[m]));

  async function loadStatus(){
    return await Orland.api("/api/blogspot/sync_status");
  }

  async function loadLogs(params = {}){
    const q = new URLSearchParams();
    if(params.limit) q.set("limit", String(params.limit));
    if(params.status) q.set("status", String(params.status));
    if(params.kind) q.set("kind", String(params.kind));
    if(params.direction) q.set("direction", String(params.direction));
    return await Orland.api("/api/blogspot/sync_logs?" + q.toString());
  }

  async function loadSafety(){ return await Orland.api("/api/blogspot/safety_config"); }

  async function loadApprovals(){
    return await Orland.api("/api/blogspot/approval_status");
  }

  async function decideApproval(local_id, decision){
    return await Orland.api("/api/blogspot/approval_decide", {
      method:"POST",
      body: JSON.stringify({ local_id, decision })
    });
  }

  async function runSync(){
    return await Orland.api("/api/blogspot/sync_run", {
      method:"POST",
      body: JSON.stringify({})
    });
  }

  async function runDrift(){
    return await Orland.api("/api/blogspot/drift_scan", {
      method:"POST",
      body: JSON.stringify({})
    });
  }

  function fmtTs(v){
    const n = Number(v || 0);
    if(!n) return "-";
    try{ return new Date(n * 1000).toLocaleString("id-ID"); }
    catch{ return String(v); }
  }

  function badgeStatus(v){
    const s = String(v || "").toLowerCase();
    if(s === "ok") return `<span class="px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-black">ok</span>`;
    if(s === "error") return `<span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-xs font-black">error</span>`;
    if(s === "running") return `<span class="px-3 py-1 rounded-full bg-sky-100 text-sky-700 text-xs font-black">running</span>`;
    if(s === "skipped") return `<span class="px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-black">skipped</span>`;
    if(s === "noop") return `<span class="px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-black">noop</span>`;
    return `<span class="px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-black">${esc(s || "unknown")}</span>`;
  }

  function badgeDirection(v){
    const s = String(v || "").toLowerCase();
    if(s === "push") return `<span class="px-2 py-1 rounded-full bg-emerald-100 text-emerald-700 text-[11px] font-black">push</span>`;
    if(s === "pull") return `<span class="px-2 py-1 rounded-full bg-sky-100 text-sky-700 text-[11px] font-black">pull</span>`;
    if(s === "system") return `<span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">system</span>`;
    return `<span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">${esc(s || "-")}</span>`;
  }

  function approvalBadge(v){
    const s = String(v || "not_required").toLowerCase();
    if(s === "approved") return `<span class="px-2 py-1 rounded-full bg-emerald-100 text-emerald-700 text-[11px] font-black">approved</span>`;
    if(s === "rejected") return `<span class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-[11px] font-black">rejected</span>`;
    if(s === "pending") return `<span class="px-2 py-1 rounded-full bg-amber-100 text-amber-700 text-[11px] font-black">pending</span>`;
    return `<span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">${esc(s)}</span>`;
  }

  function syncStateBadge(v){
    const s = String(v || "").toLowerCase();
    if(s === "approval_pending") return `<span class="px-2 py-1 rounded-full bg-violet-100 text-violet-700 text-[11px] font-black">approval pending</span>`;
    if(s === "approved_waiting_push") return `<span class="px-2 py-1 rounded-full bg-indigo-100 text-indigo-700 text-[11px] font-black">approved</span>`;
    if(s === "drift_detected") return `<span class="px-2 py-1 rounded-full bg-rose-100 text-rose-700 text-[11px] font-black">drift</span>`;
    if(s === "remote_deleted") return `<span class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-[11px] font-black">remote deleted</span>`;
    if(s === "conflict_possible") return `<span class="px-2 py-1 rounded-full bg-fuchsia-100 text-fuchsia-700 text-[11px] font-black">conflict</span>`;
    if(s === "synced") return `<span class="px-2 py-1 rounded-full bg-emerald-100 text-emerald-700 text-[11px] font-black">synced</span>`;
    if(s === "error") return `<span class="px-2 py-1 rounded-full bg-red-100 text-red-700 text-[11px] font-black">error</span>`;
    return `<span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">${esc(s || "-")}</span>`;
  }

  return {
    title:"Blogspot Sync + Approval Monitor",
    async mount(host){
      host.innerHTML = `
        <div class="space-y-4 max-w-7xl">
          <div class="flex items-center justify-between gap-3 flex-wrap">
            <div>
              <div class="text-2xl font-extrabold text-slate-900 dark:text-white">Blogspot Sync + Approval Monitor</div>
              <div class="text-sm text-slate-500">State sync, manual run, approval queue, drift scan, dan histori log.</div>
            </div>
            <div class="flex gap-2 flex-wrap">
              <button id="btnReload" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder font-black text-sm">
                <i class="fa-solid fa-rotate mr-2"></i>Reload
              </button>
              <button id="btnRunSync" class="px-4 py-3 rounded-2xl border border-emerald-200 text-emerald-700 font-black text-sm">
                <i class="fa-solid fa-play mr-2"></i>Run Sync
              </button>
              <button id="btnRunDrift" class="px-4 py-3 rounded-2xl border border-rose-200 text-rose-700 font-black text-sm">
                <i class="fa-solid fa-radar mr-2"></i>Scan Drift
              </button>
            </div>
          </div>

          <div id="msg" class="text-sm text-slate-500"></div>

          <div id="safetyBox" class="space-y-3"></div>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
              <div class="text-xs text-slate-500 font-bold">Last Run</div>
              <div id="kLastRun" class="text-sm font-extrabold mt-2">-</div>
            </div>
            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
              <div class="text-xs text-slate-500 font-bold">Last Success</div>
              <div id="kLastSuccess" class="text-sm font-extrabold mt-2">-</div>
            </div>
            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
              <div class="text-xs text-slate-500 font-bold">Last Status</div>
              <div id="kLastStatus" class="mt-2">-</div>
            </div>
            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
              <div class="text-xs text-slate-500 font-bold">Last Message</div>
              <div id="kLastMessage" class="text-sm font-extrabold mt-2 break-words">-</div>
            </div>
          </div>

          <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
              <div class="flex items-center justify-between gap-3 flex-wrap">
                <div>
                  <div class="text-xl font-extrabold">Approval Queue</div>
                  <div class="text-sm text-slate-500 mt-1">Approve, reject, atau tandai pending.</div>
                </div>
              </div>
              <div id="approvalBox" class="mt-4 space-y-3"></div>
            </div>

            <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
              <div class="text-xl font-extrabold">Filters</div>
              <div class="mt-4 flex gap-2 flex-wrap">
                <select id="fStatus" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold">
                  <option value="">All status</option>
                  <option value="ok">ok</option>
                  <option value="error">error</option>
                  <option value="running">running</option>
                  <option value="skipped">skipped</option>
                  <option value="noop">noop</option>
                </select>
                <select id="fKind" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold">
                  <option value="">All kind</option>
                  <option value="system">system</option>
                  <option value="post">post</option>
                  <option value="page">page</option>
                </select>
                <select id="fDirection" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold">
                  <option value="">All direction</option>
                  <option value="system">system</option>
                  <option value="push">push</option>
                  <option value="pull">pull</option>
                </select>
                <select id="fLimit" class="px-4 py-3 rounded-2xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-dark text-sm font-semibold">
                  <option value="20">20</option>
                  <option value="30" selected>30</option>
                  <option value="50">50</option>
                  <option value="100">100</option>
                </select>
              </div>
            </div>
          </div>

          <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
            <div class="text-xl font-extrabold">Sync Logs</div>
            <div id="logsBox" class="mt-4 space-y-3"></div>
          </div>

          <div class="rounded-3xl border border-slate-200 dark:border-darkBorder bg-white dark:bg-darkLighter p-5">
            <div class="text-xl font-extrabold">Raw Status</div>
            <pre id="rawBox" class="mt-4 text-xs whitespace-pre-wrap break-words bg-slate-50 dark:bg-black/20 border border-slate-200 dark:border-darkBorder rounded-2xl p-4">{}</pre>
          </div>
        </div>
      `;

      const q = (id)=>host.querySelector("#" + id);

      function setMsg(kind, text){
        q("msg").className = "text-sm";
        if(kind === "error") q("msg").classList.add("text-red-500");
        else if(kind === "success") q("msg").classList.add("text-emerald-600");
        else q("msg").classList.add("text-slate-500");
        q("msg").textContent = text;
      }

      function renderSafety(safety){
        const box = q("safetyBox");
        if(!box) return;
        let html = "";
        if(String(safety.write_lock_enabled || "0") === "1"){
          html += `<div class="rounded-2xl border border-red-300 bg-red-50 p-4"><div class="text-sm font-extrabold text-red-700">Emergency Write Lock Active</div><div class="text-xs text-slate-600 mt-2">Remote write should be blocked.</div></div>`;
        }
        if(String(safety.maintenance_mode || "0") === "1"){
          html += `<div class="rounded-2xl border border-amber-300 bg-amber-50 p-4"><div class="text-sm font-extrabold text-amber-700">Maintenance Mode Active</div><div class="text-xs text-slate-600 mt-2">${esc(safety.maintenance_notice || "Production maintenance mode is active.")}</div></div>`;
        }
        box.innerHTML = html;
      }

      function setMsg(kind, text){
        q("msg").className = "text-sm";
        if(kind === "error") q("msg").classList.add("text-red-500");
        else if(kind === "success") q("msg").classList.add("text-emerald-600");
        else q("msg").classList.add("text-slate-500");
        q("msg").textContent = text;
      }

      function renderLogs(items){
        if(!items.length){
          q("logsBox").innerHTML = `<div class="text-sm text-slate-500">No sync logs.</div>`;
          return;
        }

        q("logsBox").innerHTML = items.map(x => `
          <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div class="min-w-0">
                <div class="flex gap-2 flex-wrap">
                  ${badgeStatus(x.status)}
                  ${badgeDirection(x.direction)}
                  <span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">${esc(x.kind || "-")}</span>
                  <span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">${esc(x.action || "-")}</span>
                </div>
                <div class="text-sm font-extrabold mt-3 break-words">${esc(x.message || "-")}</div>
                <div class="text-xs text-slate-500 mt-2">
                  ${esc(fmtTs(x.created_at))} • local: ${esc(x.local_id || "-")} • remote: ${esc(x.remote_id || "-")}
                </div>
              </div>
            </div>
            <pre class="mt-3 text-[11px] whitespace-pre-wrap break-words bg-slate-50 dark:bg-black/20 border border-slate-200 dark:border-darkBorder rounded-2xl p-3">${esc(JSON.stringify(x.payload_json || {}, null, 2))}</pre>
          </div>
        `).join("");
      }

      function renderApprovals(items){
        if(!items.length){
          q("approvalBox").innerHTML = `<div class="text-sm text-slate-500">No approval queue.</div>`;
          return;
        }

        q("approvalBox").innerHTML = items.map(x => `
          <div class="rounded-2xl border border-slate-200 dark:border-darkBorder p-4">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div class="min-w-0">
                <div class="flex gap-2 flex-wrap">
                  <span class="px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-[11px] font-black">${esc(x.kind || "-")}</span>
                  ${approvalBadge(x.approval_status)}
                  ${syncStateBadge(x.sync_state)}
                </div>
                <div class="text-sm font-extrabold mt-3">${esc(x.title || x.local_id)}</div>
                <div class="text-xs text-slate-500 mt-1">${esc(x.slug || x.local_id || "-")}</div>
                <div class="text-[11px] text-slate-400 mt-2">approved_by: ${esc(x.approved_by || "-")} • approved_at: ${esc(fmtTs(x.approved_at))}</div>
              </div>
              <div class="flex gap-2 flex-wrap">
                <button class="btnApprove px-3 py-2 rounded-xl border border-emerald-200 text-emerald-700 text-xs font-black" data-id="${esc(x.local_id)}">Approve</button>
                <button class="btnReject px-3 py-2 rounded-xl border border-red-200 text-red-700 text-xs font-black" data-id="${esc(x.local_id)}">Reject</button>
                <button class="btnPending px-3 py-2 rounded-xl border border-amber-200 text-amber-700 text-xs font-black" data-id="${esc(x.local_id)}">Pending</button>
              </div>
            </div>
          </div>
        `).join("");

        q("approvalBox").querySelectorAll(".btnApprove").forEach(btn => {
          btn.onclick = ()=>submitDecision(btn.getAttribute("data-id"), "approved");
        });
        q("approvalBox").querySelectorAll(".btnReject").forEach(btn => {
          btn.onclick = ()=>submitDecision(btn.getAttribute("data-id"), "rejected");
        });
        q("approvalBox").querySelectorAll(".btnPending").forEach(btn => {
          btn.onclick = ()=>submitDecision(btn.getAttribute("data-id"), "pending");
        });
      }

      async function submitDecision(local_id, decision){
        setMsg("muted", `Saving approval: ${decision} ...`);
        const r = await decideApproval(local_id, decision);
        if(r.status !== "ok"){
          setMsg("error", "Approval save failed: " + (r.data?.error || r.status));
          return;
        }
        setMsg("success", "Approval updated.");
        await render();
      }

      async function render(){
        setMsg("muted", "Loading sync monitor...");

        const [statusRes, logsRes, approvalRes, safetyRes] = await Promise.all([
          loadStatus(),
          loadLogs({
            limit: q("fLimit").value,
            status: q("fStatus").value,
            kind: q("fKind").value,
            direction: q("fDirection").value
          }),
          loadApprovals(),
          loadSafety()
        ]);

        renderSafety(safetyRes.status === "ok" ? (safetyRes.data || {}) : {});

        q("rawBox").textContent = JSON.stringify({
          sync_status: statusRes,
          logs: logsRes,
          approvals: approvalRes
        }, null, 2);

        if(statusRes.status !== "ok"){
          setMsg("error", "Load status failed: " + statusRes.status);
          return;
        }

        const st = statusRes.data || {};
        const state = st.state || {};

        q("kLastRun").textContent = fmtTs(state.last_run_at);
        q("kLastSuccess").textContent = fmtTs(state.last_success_at);
        q("kLastStatus").innerHTML = badgeStatus(state.last_status || "idle");
        q("kLastMessage").textContent = state.last_message || "-";

        if(logsRes.status !== "ok"){
          q("logsBox").innerHTML = `<pre class="text-[11px] whitespace-pre-wrap text-red-500">${esc(JSON.stringify(logsRes, null, 2))}</pre>`;
          setMsg("error", "Load logs failed: " + logsRes.status);
          return;
        }

        if(approvalRes.status !== "ok"){
          q("approvalBox").innerHTML = `<pre class="text-[11px] whitespace-pre-wrap text-red-500">${esc(JSON.stringify(approvalRes, null, 2))}</pre>`;
          setMsg("error", "Load approvals failed: " + approvalRes.status);
          return;
        }

        renderLogs(Array.isArray(logsRes.data?.items) ? logsRes.data.items : []);
        renderApprovals(Array.isArray(approvalRes.data?.items) ? approvalRes.data.items : []);
        setMsg("success", "Loaded.");
      }

      q("btnReload").onclick = render;

      q("btnRunSync").onclick = async ()=>{
        setMsg("muted", "Running sync...");
        const r = await runSync();
        q("rawBox").textContent = JSON.stringify(r, null, 2);
        if(r.status !== "ok"){
          setMsg("error", "Run sync failed: " + r.status);
          return;
        }
        setMsg("success", "Sync executed.");
        await render();
      };

      q("btnRunDrift").onclick = async ()=>{
        setMsg("muted", "Running drift scan...");
        const r = await runDrift();
        q("rawBox").textContent = JSON.stringify(r, null, 2);
        if(r.status !== "ok"){
          setMsg("error", "Drift scan failed: " + r.status);
          return;
        }
        setMsg("success", "Drift scan executed.");
        await render();
      };

      q("fStatus").onchange = render;
      q("fKind").onchange = render;
      q("fDirection").onchange = render;
      q("fLimit").onchange = render;

      await render();
    }
  };
}
